{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",

                "/I",
                "C:\\vcpkg\\installed\\x64-windows\\include",

                "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",

                "${file}",

                "/link",

                "/LIBPATH:C:\\vcpkg\\installed\\x64-windows\\lib",

                "libssl.lib",
                "libcrypto.lib"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}